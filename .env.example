# Hive API Keys
# Copy this to .env and fill in your keys
# Keys are loaded SAFELY — never injected into os.environ
# Claude Code session will NOT see these keys

# Anthropic (Claude models)
ANTHROPIC_API_KEY=

# OpenAI (GPT models)
OPENAI_API_KEY=

# Fireworks AI (fast open-source models)
FIREWORKS_API_KEY=

# Ollama (local models - no key needed, just the URL)
OLLAMA_BASE_URL=http://localhost:11434

# LM Studio (local models via OpenAI-compatible API)
LMSTUDIO_BASE_URL=http://localhost:1234
